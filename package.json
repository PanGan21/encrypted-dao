{
  "name": "encrypted-dao",
  "version": "1.0.0",
  "description": "Encrypted Aragon — Private DAO Framework using Fully Homomorphic Encryption (fhEVM)",
  "license": "BSD-3-Clause-Clear",
  "engines": {
    "node": ">=20",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "clean": "rimraf ./fhevmTemp ./artifacts ./cache ./coverage ./types ./coverage.json ./dist && npm run typechain",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "postcompile": "npm run typechain",
    "test": "hardhat test",
    "test:sepolia": "hardhat test --network sepolia",
    "coverage": "cross-env SOLIDITY_COVERAGE=true hardhat coverage --solcoverjs ./.solcover.js --temp artifacts --testfiles \"test/**/*.ts\" && npm run typechain",
    "typechain": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "deploy:localhost": "hardhat deploy --network localhost",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "upgrade:localhost": "hardhat run scripts/upgrade.ts --network localhost",
    "upgrade:sepolia": "hardhat run scripts/upgrade.ts --network sepolia",
    "view-proposal": "hardhat run scripts/viewAndDecryptProposal.ts --network sepolia",
    "chain": "hardhat node --network hardhat --no-deploy",
    "test:e2e": "hardhat test test/e2e.test.ts",
    "test:e2e:localhost": "hardhat test test/e2e.test.ts --network localhost",
    "lint": "eslint . && solhint 'contracts/**/*.sol'",
    "lint:fix": "eslint . --fix",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write '**/*.{ts,js,json,sol,md}'",
    "format:check": "prettier --check '**/*.{ts,js,json,sol,md}'"
  },
  "dependencies": {
    "@fhevm/mock-utils": "^0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "encrypted-types": "^0.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@zama-fhe/relayer-sdk": "^0.4.1",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.4",
    "hardhat-deploy": "^0.11.45",
    "hardhat-gas-reporter": "^2.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^6.1.2",
    "solhint": "^6.1.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
