# Set Hardhat vars with: npx hardhat vars set MNEMONIC
# MNEMONIC="test test test test test test test test test test test junk"
# INFURA_API_KEY=your_infura_api_key
# ETHERSCAN_API_KEY=your_etherscan_key

# Optional: trusted forwarder for EIP-2771 meta-tx (default: disabled)
TRUSTED_FORWARDER=

# Optional: deploy multisig plugin
DEPLOY_MULTISIG=false
MULTISIG_SIGNERS=0xAddr1,0xAddr2,0xAddr3
MULTISIG_THRESHOLD=2

# For viewAndDecryptProposal script
PLUGIN_TYPE=voting
PLUGIN_CONTRACT_ADDRESS=
PROPOSAL_ID=1
